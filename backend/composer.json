{
    "name": "silverstripe/installer",
    "type": "silverstripe-recipe",
    "description": "The SilverStripe Framework Installer",
    "require": {
        "php": "^8.2",
        "silverstripe/recipe-cms": "5.4.0",
        "zircote/swagger-php": "^5.0.4",
        "tuupola/base62": "^2.1.0",
        "ramsey/uuid": "^4.7.6",
        "guzzlehttp/guzzle": "^7.9.2",
        "symbiote/silverstripe-gridfieldextensions": "^4.1.0",
        "silverstripe/s3": "^4.0.2",
        "nathancox/hasoneautocompletefield": "^2.13.0",
        "ext-json": "*",
        "jumbojett/openid-connect-php": "^1.0.2",
        "laravel/helpers": "^1.7.2",
        "bigfork/silverstripe-oauth-login": "^2.3.1",
        "firebase/php-jwt": "^6.11.0",
        "matomo/matomo-php-tracker": "^3.3.2",
        "symfony/amazon-mailer": "*"
    },
    "require-dev": {
        "phpunit/phpunit": ">=5.7"
    },
    "extra": {
        "resources-dir": "_resources",
        "project-files-installed": [
            "app/.htaccess",
            "app/_config.php",
            "app/_config/mimevalidator.yml",
            "app/_config/mysite.yml",
            "app/src/Page.php",
            "app/src/PageController.php"
        ],
        "public-files-installed": [
            ".htaccess",
            "index.php",
            "web.config"
        ],
        "expose": [
            "app/src/javascript",
            "themes/surfsharekit/css",
            "themes/surfsharekit/images",
            "themes/surfsharekit/javascript"
        ]
    },
    "config": {
        "process-timeout": 600,
        "allow-plugins": {
            "composer/installers": true,
            "silverstripe/recipe-plugin": true,
            "silverstripe/vendor-plugin": true,
            "kylekatarnls/update-helper": false
        }
    },
    "prefer-stable": true,
    "minimum-stability": "dev"
}
